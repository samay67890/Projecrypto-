# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (SQLite by default)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Email Configuration (Brevo SMTP)
# IMPORTANT: You need a Brevo account to send OTP emails.
#
# Step-by-step instructions:
# 1. Sign up at https://www.brevo.com/
# 2. Go to: Settings → SMTP & API → SMTP tab
# 3. Note the "Login" value (e.g. a53e3f001@smtp-brevo.com) — this is EMAIL_HOST_USER
# 4. Click "Generate a new SMTP key" and copy the key — this is EMAIL_HOST_PASSWORD
# 5. Go to: Settings → Senders, Domains & Dedicated IPs → Senders
# 6. Add and verify the email you want to send from — this is DEFAULT_FROM_EMAIL
#
# For development/testing without email setup, use console backend:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# (OTP will be printed in terminal instead of sent via email)

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-brevo-login@smtp-brevo.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=your-verified-sender@example.com

# Optional: CoinAPI key for dashboard historical chart
# Without this key, dashboard chart falls back to Binance historical candles.
COINAPI_API_KEY=
BINANCE_API_KEY=
