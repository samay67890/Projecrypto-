# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (SQLite by default)
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Email Configuration (Gmail SMTP)
# IMPORTANT: For emails to work, you MUST set up a Gmail App Password
# 
# Step-by-step instructions:
# 1. Go to: https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already enabled
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Select "Mail" as the app and "Other" as device
# 5. Name it "NexusCrypto" and click Generate
# 6. Copy the 16-character password (no spaces)
# 7. Paste it below replacing "your-gmail-app-password-here"
#
# For development/testing without email setup, use console backend:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# (OTP will be printed in terminal instead of sent via email)

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tempmailwokr@gmail.com
EMAIL_HOST_PASSWORD=""
DEFAULT_FROM_EMAIL=tempmailwokr@gmail.com

# Optional: CoinAPI key for dashboard historical chart
# Without this key, dashboard chart falls back to Binance historical candles.
COINAPI_API_KEY=
BINANCE_API_KEY=
